<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WBNN WeatherCast – Delta v3.0f</title>

  <style>
    :root{
      --bg:#dff5ff;
      --bg2:#c8ecfb;
      --panel:#ffffff;
      --panel2:#f6fcff;
      --border:#b7dfef;
      --accent:#59c2eb;
      --accent2:#2f99c9;
      --text:#123246;
      --muted:#4f7385;
      --good:#1f9d63;
      --warn:#d98c00;
      --bad:#c74d4d;
      --shadow:0 10px 30px rgba(18,50,70,0.08);
      --radius:16px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}

    body{
      margin:0;
      font-family:Arial,Helvetica,sans-serif;
      background:linear-gradient(180deg,var(--bg),var(--bg2));
      color:var(--text);
      overflow-x:hidden;
    }

    .wrap{
      width:min(1400px, calc(100vw - 64px));
      margin:0 auto;
      padding:24px;
      transform:translateX(-24%);
    }

    .panel{
      background:var(--panel);
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:20px;
      margin-bottom:20px;
      box-shadow:var(--shadow);
    }

    .hero{
      background:linear-gradient(135deg, rgba(89,194,235,.18), rgba(255,255,255,.96));
      overflow:hidden;
      position:relative;
    }

    .hero-top{
      display:flex;
      justify-content:space-between;
      gap:16px;
      align-items:flex-start;
      flex-wrap:wrap;
    }

    .eyebrow{
      display:inline-block;
      font-size:12px;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:var(--accent2);
      margin-bottom:10px;
    }

    h1,h2,h3,h4{
      margin:0 0 10px;
      line-height:1.2;
    }

    p{line-height:1.5;margin:0 0 12px}
    .muted{color:var(--muted)}
    .small{font-size:12px;color:var(--muted)}
    .tiny{font-size:11px;color:var(--muted)}

    .status-bar{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:14px;
    }

    .status-pill{
      background:#eefaff;
      border:1px solid var(--border);
      border-radius:999px;
      padding:8px 12px;
      font-size:12px;
      font-weight:700;
      color:var(--text);
    }

    .live-strip{
      display:flex;
      align-items:center;
      gap:12px;
      border:1px solid var(--border);
      background:linear-gradient(180deg,#fff,#f2fbff);
      border-radius:14px;
      padding:12px 16px;
      margin-top:16px;
      overflow:hidden;
    }

    .live-label{
      font-size:12px;
      font-weight:800;
      color:var(--accent2);
      white-space:nowrap;
      text-transform:uppercase;
      letter-spacing:.06em;
      flex:0 0 auto;
    }

    .ticker-viewport{
      min-width:0;
      overflow:hidden;
      width:100%;
      position:relative;
      height:22px;
    }

    .ticker-track{
      display:inline-block;
      white-space:nowrap;
      will-change:transform;
      animation:tickerScroll 28s linear infinite;
      padding-left:100%;
      font-size:13px;
      font-weight:700;
      color:var(--text);
    }

    @keyframes tickerScroll{
      0%{transform:translateX(0)}
      100%{transform:translateX(-100%)}
    }

    .section-head{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:wrap;
      margin-bottom:14px;
    }

    .section-head-left{
      min-width:0;
      flex:1 1 auto;
    }

    .section-head-right{
      flex:0 0 auto;
      display:flex;
      align-items:center;
      gap:10px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .partner-tag{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:7px 11px;
      border-radius:999px;
      border:1px solid var(--border);
      background:#f4fbff;
      font-size:12px;
      color:var(--muted);
      font-weight:700;
      white-space:nowrap;
    }

    .partner-tag a{
      color:var(--accent2);
      text-decoration:none;
      font-weight:800;
    }

    .badge-d{
      display:inline-flex;
      justify-content:center;
      align-items:center;
      width:22px;
      height:22px;
      border-radius:999px;
      background:var(--accent2);
      color:#fff;
      font-size:11px;
      font-weight:800;
      vertical-align:middle;
      margin-left:8px;
    }

    .grid{
      display:grid;
      gap:20px;
    }

    .grid-2{grid-template-columns:1fr 1fr}
    .grid-3{grid-template-columns:repeat(3,1fr)}
    .grid-4{grid-template-columns:repeat(4,1fr)}
    .grid-6{grid-template-columns:repeat(6,1fr)}

    .metric-card,
    .info-card,
    .impact-card,
    .timeline-item,
    .forecast-day,
    .micro-card,
    .partner-card,
    .admin-card,
    .alert-box,
    .decision-card{
      border:1px solid var(--border);
      border-radius:14px;
      padding:16px;
      background:linear-gradient(180deg,#fff,#f5fcff);
    }

    .metric-label{
      font-size:12px;
      color:var(--muted);
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.05em;
      margin-bottom:8px;
    }

    .metric-value{
      font-size:34px;
      font-weight:800;
      letter-spacing:-.02em;
      margin-bottom:8px;
    }

    .metric-sub{
      font-size:13px;
      color:var(--muted);
    }

    .brief-box{
      border:1px solid var(--border);
      background:linear-gradient(180deg,#ffffff,#f2fbff);
      border-radius:14px;
      padding:18px;
    }

    .decision-lead{
      font-size:18px;
      font-weight:800;
      color:var(--text);
      margin-bottom:14px;
    }

    .decision-grid{
      display:grid;
      grid-template-columns:1.2fr .9fr .9fr .8fr;
      gap:14px;
    }

    .decision-list{
      margin:0;
      padding-left:18px;
      color:var(--text);
    }

    .decision-list li{
      margin:0 0 10px;
      line-height:1.45;
    }

    .decision-chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:7px 11px;
      border-radius:999px;
      border:1px solid var(--border);
      background:#eefaff;
      font-size:12px;
      font-weight:800;
      color:var(--accent2);
      margin-bottom:10px;
    }

    .decision-copy{
      color:var(--muted);
      line-height:1.45;
      font-size:14px;
    }

    .impact-grid{
      display:grid;
      grid-template-columns:repeat(6,1fr);
      gap:14px;
    }

    .impact-score{
      font-size:24px;
      font-weight:800;
      margin:6px 0;
    }

    .score-good{color:var(--good)}
    .score-warn{color:var(--warn)}
    .score-bad{color:var(--bad)}

    .timeline{
      display:grid;
      grid-template-columns:repeat(8,1fr);
      gap:10px;
      overflow:auto;
    }

    .timeline-item{
      min-width:110px;
      text-align:center;
    }

    .forecast-grid{
      display:grid;
      grid-template-columns:repeat(7,1fr);
      gap:12px;
    }

    .forecast-day .day{
      font-size:13px;
      font-weight:800;
      margin-bottom:8px;
    }

    .forecast-day .temps{
      font-size:22px;
      font-weight:800;
      margin:10px 0 8px;
    }

    .map-toolbar{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-bottom:12px;
    }

    .tab-btn,.btn,.mini-btn{
      border:none;
      border-radius:10px;
      background:var(--accent);
      color:#fff;
      cursor:pointer;
      font-weight:700;
      box-shadow:var(--shadow);
      font-family:inherit;
    }

    .tab-btn{padding:10px 14px;font-size:13px}
    .btn{padding:11px 16px;font-size:14px}
    .mini-btn{padding:7px 10px;font-size:12px}

    .tab-btn.secondary,.btn.secondary,.mini-btn.secondary{
      background:#edf8fd;
      color:var(--text);
      border:1px solid var(--border);
      box-shadow:none;
    }

    .tab-btn.active{background:var(--accent2)}

    .map-frame{
      width:100%;
      height:520px;
      border:1px solid var(--border);
      border-radius:14px;
      overflow:hidden;
      background:#eef9fe;
    }

    .map-frame iframe{
      width:100%;
      height:100%;
      border:0;
    }

    .alerts-wrap{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:16px;
    }

    .alert-tag{
      display:inline-block;
      padding:6px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:800;
      margin-bottom:10px;
    }

    .tag-good{background:#e8f8ef;color:var(--good)}
    .tag-warn{background:#fff5df;color:var(--warn)}
    .tag-bad{background:#fdecec;color:var(--bad)}

    .micro-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:12px;
    }

    .partner-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:12px;
    }

    .field{margin-bottom:12px}

    .field label{
      display:block;
      margin-bottom:6px;
      font-size:12px;
      font-weight:700;
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.04em;
    }

    .field input,
    .field textarea,
    .field select{
      width:100%;
      min-height:46px;
      font-size:14px;
      padding:10px 12px;
      border:1px solid var(--border);
      border-radius:10px;
      outline:none;
      font-family:inherit;
      background:#fff;
      color:var(--text);
    }

    .field textarea{
      min-height:120px;
      resize:vertical;
    }

    .admin-shell{display:none}
    .admin-shell.open{display:block}

    .admin-grid{
      display:grid;
      grid-template-columns:1.15fr .85fr;
      gap:18px;
    }

    .list-row{
      border:1px solid var(--border);
      border-radius:12px;
      padding:12px;
      background:#fff;
      margin-bottom:10px;
    }

    .row-actions{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:10px;
    }

    .footer-note{
      font-size:12px;
      color:var(--muted);
      text-align:left;
      margin-top:28px;
    }

    .changelog{
      margin:0;
      padding-left:18px;
    }

    .loader{
      color:var(--muted);
      font-size:14px;
    }

    @media (max-width:1200px){
      .decision-grid{
        grid-template-columns:1fr 1fr;
      }
      .wrap{
        transform:translateX(-14%);
      }
    }

    @media (max-width:1100px){
      .grid-2,.grid-3,.grid-4,.grid-6,.forecast-grid,.impact-grid,.micro-grid,.partner-grid,.alerts-wrap,.admin-grid{
        grid-template-columns:1fr 1fr;
      }
      .timeline{grid-template-columns:repeat(4,1fr)}
    }

    @media (max-width:760px){
      .wrap{
        width:calc(100vw - 24px);
        transform:none;
        padding:12px;
      }
      .grid-2,.grid-3,.grid-4,.grid-6,.forecast-grid,.impact-grid,.micro-grid,.partner-grid,.alerts-wrap,.admin-grid,.decision-grid{
        grid-template-columns:1fr;
      }
      .timeline{grid-template-columns:repeat(2,1fr)}
      .map-frame{height:420px}
      .metric-value{font-size:28px}
      .ticker-track{animation-duration:20s}
      .decision-lead{font-size:16px}
    }
  </style>
</head>
<body>
<div class="wrap">

  <div class="panel hero">
    <div class="hero-top">
      <div>
        <div class="eyebrow">WBNN WeatherCast™</div>
        <h1 id="heroTitle">WeatherCast Terminal™ – Delta</h1>
        <p id="heroSubtitle" class="muted" style="max-width:780px;">
          A dedicated city weather intelligence dashboard delivering real-time atmospheric conditions, forecasts, environmental signals, and city impact insights for Delta City.
        </p>
        <div class="status-bar">
          <div class="status-pill">Dynamic Weather Data <span class="badge-d">D</span></div>
          <div class="status-pill" id="refreshStatus">Refreshing in 15:00</div>
          <div class="status-pill" id="updatedStamp">Updated: --</div>
          <div class="status-pill" id="sourceStamp">Source: Open-Meteo + Windy</div>
        </div>
      </div>
    </div>

    <div class="live-strip">
      <div class="live-label">WeatherCast – Delta Update</div>
      <div class="ticker-viewport">
        <div class="ticker-track" id="tickerTrack">Loading live update…</div>
      </div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Today’s Decision Panel <span class="badge-d">D</span></h2>
        <div class="small">A plain-language interpretation layer that turns today’s weather into practical guidance.</div>
      </div>
    </div>

    <div class="decision-lead" id="decisionLead">Generating today’s decision summary…</div>

    <div class="decision-grid">
      <div class="decision-card">
        <div class="metric-label">What To Do</div>
        <ul class="decision-list" id="decisionActions">
          <li>Loading daily guidance…</li>
        </ul>
      </div>

      <div class="decision-card">
        <div class="decision-chip">Best Window</div>
        <div class="decision-copy" id="decisionWindow">Checking the best time to be outside…</div>
      </div>

      <div class="decision-card">
        <div class="decision-chip">Commute Note</div>
        <div class="decision-copy" id="decisionCommute">Assessing likely travel friction…</div>
      </div>

      <div class="decision-card">
        <div class="decision-chip">Forecast Confidence</div>
        <div class="decision-copy" id="decisionConfidence">Calculating forecast confidence…</div>
      </div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Delta Conditions Panel <span class="badge-d">D</span></h2>
        <div class="small">Live current conditions for Delta, British Columbia.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-conditions"></div>
      </div>
    </div>

    <div class="grid grid-4">
      <div class="metric-card">
        <div class="metric-label">Temperature</div>
        <div class="metric-value" id="tempNow">--°C</div>
        <div class="metric-sub" id="conditionNow">Loading current conditions…</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Feels Like</div>
        <div class="metric-value" id="feelsNow">--°C</div>
        <div class="metric-sub" id="humidityNow">Humidity --%</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Wind</div>
        <div class="metric-value" id="windNow">-- km/h</div>
        <div class="metric-sub" id="windDirNow">Direction --</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Rain Risk</div>
        <div class="metric-value" id="rainRiskNow">--%</div>
        <div class="metric-sub" id="highLowNow">High / Low --° / --°</div>
      </div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Delta Weather Brief <span class="badge-d">D</span></h2>
        <div class="small">A plain-language interpretation of the data for Delta readers.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-brief"></div>
      </div>
    </div>

    <div class="brief-box">
      <p id="weatherBrief" class="muted">Loading forecast summary…</p>
      <div class="grid grid-3" style="margin-top:14px;">
        <div class="info-card">
          <div class="metric-label">Sunrise / Sunset</div>
          <div style="font-weight:800;" id="sunNow">-- / --</div>
        </div>
        <div class="info-card">
          <div class="metric-label">UV Peak</div>
          <div style="font-weight:800;" id="uvPeak">--</div>
        </div>
        <div class="info-card">
          <div class="metric-label">Precipitation Today</div>
          <div style="font-weight:800;" id="precipToday">-- mm</div>
        </div>
      </div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Delta Impact Readout <span class="badge-d">D</span></h2>
        <div class="small">A fast planning layer for commutes, jobsites, events, and outdoor use.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-impact"></div>
      </div>
    </div>

    <div class="impact-grid">
      <div class="impact-card">
        <div class="metric-label">Commute Risk</div>
        <div class="impact-score" id="scoreCommute">Loading…</div>
        <div class="tiny" id="textCommute">Assessing rain, visibility, and wind.</div>
      </div>
      <div class="impact-card">
        <div class="metric-label">Outdoor Score</div>
        <div class="impact-score" id="scoreOutdoor">Loading…</div>
        <div class="tiny" id="textOutdoor">Checking comfort and dry windows.</div>
      </div>
      <div class="impact-card">
        <div class="metric-label">Marine</div>
        <div class="impact-score" id="scoreMarine">Loading…</div>
        <div class="tiny" id="textMarine">Looking at wind and coastal exposure.</div>
      </div>
      <div class="impact-card">
        <div class="metric-label">Air Quality</div>
        <div class="impact-score score-warn" id="scoreAir">Watch</div>
        <div class="tiny" id="textAir">Local AQI feed can be layered in later.</div>
      </div>
      <div class="impact-card">
        <div class="metric-label">Event Readiness</div>
        <div class="impact-score" id="scoreEvent">Loading…</div>
        <div class="tiny" id="textEvent">Checking rain timing and temperature.</div>
      </div>
      <div class="impact-card">
        <div class="metric-label">Construction</div>
        <div class="impact-score" id="scoreBuild">Loading…</div>
        <div class="tiny" id="textBuild">Watching rain and wind disruption risk.</div>
      </div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Today Timeline View <span class="badge-d">D</span></h2>
        <div class="small">How the day unfolds hour by hour, including rain timing, wind shift, and usable outdoor windows.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-timeline"></div>
      </div>
    </div>

    <div class="timeline" id="timelineWrap">
      <div class="timeline-item loader">Loading timeline…</div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Weather Radar View <span class="badge-d">D</span></h2>
        <div class="small">Switch between radar, satellite, wind, cloud, rain, and temperature overlays.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-map"></div>
      </div>
    </div>

    <div class="map-toolbar">
      <button class="tab-btn active" data-overlay="radar">Radar</button>
      <button class="tab-btn secondary" data-overlay="satellite">Satellite</button>
      <button class="tab-btn secondary" data-overlay="wind">Wind</button>
      <button class="tab-btn secondary" data-overlay="clouds">Clouds</button>
      <button class="tab-btn secondary" data-overlay="rain">Rain</button>
      <button class="tab-btn secondary" data-overlay="temp">Temperature</button>
    </div>
    <div class="map-frame">
      <iframe id="windyFrame" title="Windy Weather Map" loading="lazy"></iframe>
    </div>
    <div class="small" id="mapStatus" style="margin-top:10px;">Radar view active.</div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>7-Day Outlook <span class="badge-d">D</span></h2>
        <div class="small">The pattern of the week ahead, including temperature trend, precipitation risk, and practical planning value.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-forecast"></div>
      </div>
    </div>

    <div class="forecast-grid" id="forecastWrap">
      <div class="forecast-day loader">Loading 7-day forecast…</div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Delta Alerts & Advisories</h2>
        <div class="small">A dedicated alerts area for automated threshold detection plus an admin bulletin override.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-alerts"></div>
      </div>
    </div>

    <div class="alerts-wrap">
      <div class="alert-box">
        <div id="autoAlertTag" class="alert-tag tag-good">Monitoring</div>
        <h3 style="margin-top:0;">Automated Weather Risk Readout</h3>
        <p id="autoAlertText" class="muted">Reviewing forecast thresholds now.</p>
        <div class="small" id="autoAlertMeta">Rain, wind, and temperature triggers are being checked.</div>
      </div>

      <div class="alert-box">
        <div id="manualAlertTag" class="alert-tag tag-good">Official Links Ready</div>
        <h3 style="margin-top:0;">Official Alert Access + Admin Override</h3>
        <p id="manualAlertText" class="muted">Use the buttons below to open official forecast sources or post a local admin bulletin.</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px;">
          <a id="ecForecastLink" class="btn secondary" href="#" target="_blank" rel="noopener">View Official Forecast</a>
          <a id="ecAlertsLink" class="btn secondary" href="#" target="_blank" rel="noopener">Environment Canada</a>
        </div>
      </div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Delta Microclimates <span class="badge-d">D</span></h2>
        <div class="small">A hyperlocal scan across North Delta, Ladner, Tsawwassen, and Boundary Bay/waterfront conditions.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-micro"></div>
      </div>
    </div>

    <div class="micro-grid" id="microWrap">
      <div class="micro-card loader">Loading neighbourhood conditions…</div>
    </div>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Partner Spotlight</h2>
        <div class="small">Featured local partners and rotating sponsor placements across the WeatherCast.</div>
      </div>
      <div class="section-head-right">
        <div class="partner-tag" id="tag-partner"></div>
      </div>
    </div>

    <div class="partner-grid" id="partnerGrid">
      <div class="partner-card">
        <h3>Open Partner Slot</h3>
        <p class="muted">Add partner cards from the admin console.</p>
      </div>
    </div>
  </div>

  <div class="panel">
    <h2>About WeatherCast Terminal™</h2>
    <p class="muted" id="explainerText">
      WeatherCast Terminal™ is a live city weather intelligence dashboard built to surface current conditions, forecast shifts, and practical local impact signals in one place—so readers can see what’s happening now and make smarter day-to-day decisions.
    </p>
  </div>

  <div class="panel">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Admin Access</h2>
        <div class="small">Use the password to open the private WeatherCast control panel.</div>
      </div>
    </div>
    <div class="grid grid-2">
      <div class="field">
        <label for="adminPasswordInput">Admin Password</label>
        <input id="adminPasswordInput" type="password" placeholder="Enter admin password" />
      </div>
      <div style="display:flex;align-items:end;gap:10px;flex-wrap:wrap;">
        <button class="btn" id="unlockAdminBtn">Open Admin Console</button>
        <button class="btn secondary" id="lockAdminBtn">Close Admin Console</button>
      </div>
    </div>
  </div>

  <div class="panel admin-shell" id="adminShell">
    <div class="section-head">
      <div class="section-head-left">
        <h2>Admin Console</h2>
        <div class="small">Public/Admin separation, settings, partner management, bulletins, backup, import, archive, restore, and continuity controls.</div>
      </div>
    </div>

    <div class="admin-grid">
      <div>
        <div class="admin-card">
          <h3>Platform Settings</h3>

          <div class="field">
            <label>Hero Title</label>
            <input id="setTitle" />
          </div>

          <div class="field">
            <label>Hero Subtitle</label>
            <textarea id="setSubtitle"></textarea>
          </div>

          <div class="field">
            <label>Explainer Copy</label>
            <textarea id="setExplainer"></textarea>
          </div>

          <div class="grid grid-2">
            <div class="field">
              <label>Location Name</label>
              <input id="setLocationName" />
            </div>
            <div class="field">
              <label>Timezone</label>
              <input id="setTimezone" />
            </div>
          </div>

          <div class="grid grid-2">
            <div class="field">
              <label>Latitude</label>
              <input id="setLat" type="number" step="0.0001" />
            </div>
            <div class="field">
              <label>Longitude</label>
              <input id="setLon" type="number" step="0.0001" />
            </div>
          </div>

          <div class="grid grid-2">
            <div class="field">
              <label>Windy Zoom</label>
              <input id="setZoom" type="number" step="1" />
            </div>
            <div class="field">
              <label>Refresh Minutes</label>
              <input id="setRefresh" type="number" step="1" />
            </div>
          </div>

          <div class="grid grid-2">
            <div class="field">
              <label>Official Forecast URL</label>
              <input id="setForecastUrl" />
            </div>
            <div class="field">
              <label>Official Alerts URL</label>
              <input id="setAlertsUrl" />
            </div>
          </div>

          <div class="field">
            <label>Admin Password</label>
            <input id="setAdminPassword" type="text" />
          </div>

          <button class="btn" id="saveSettingsBtn">Save Settings</button>
        </div>

        <div class="admin-card">
          <h3>Manual Bulletin / Alert Override</h3>

          <div class="field">
            <label>Bulletin Title</label>
            <input id="bulletinTitle" placeholder="Example: Wind advisory for waterfront routes" />
          </div>

          <div class="field">
            <label>Bulletin Copy</label>
            <textarea id="bulletinText" placeholder="Short local interpretation for Delta readers."></textarea>
          </div>

          <div class="grid grid-2">
            <div class="field">
              <label>Status</label>
              <select id="bulletinLevel">
                <option value="good">Monitoring</option>
                <option value="warn">Advisory</option>
                <option value="bad">Warning</option>
              </select>
            </div>
            <div class="field">
              <label>Applies To</label>
              <input id="bulletinScope" placeholder="North Delta / Ladner / Tsawwassen / All Delta" />
            </div>
          </div>

          <button class="btn" id="addBulletinBtn">Add Bulletin</button>
        </div>

        <div class="admin-card">
          <h3>Partner Manager</h3>

          <div class="field">
            <label>Partner Name</label>
            <input id="partnerName" />
          </div>

          <div class="field">
            <label>Partner Description</label>
            <textarea id="partnerDesc"></textarea>
          </div>

          <div class="field">
            <label>Partner URL</label>
            <input id="partnerUrl" />
          </div>

          <button class="btn" id="addPartnerBtn">Add Partner</button>
        </div>

        <div class="admin-card">
          <h3>Backup & Continuity</h3>
          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <button class="btn" id="exportBackupBtn">Export Backup</button>
            <label class="btn secondary" style="display:inline-flex;align-items:center;gap:8px;cursor:pointer;">
              Import Backup
              <input id="importBackupInput" type="file" accept=".json,application/json" style="display:none;" />
            </label>
          </div>
          <div class="small" style="margin-top:10px;">Export includes settings, partners, archive, active bulletins, and metadata.</div>
        </div>
      </div>

      <div>
        <div class="admin-card">
          <h3>Active Bulletins</h3>
          <div id="bulletinList"></div>
        </div>

        <div class="admin-card">
          <h3>Archived Bulletins</h3>
          <div id="archiveList"></div>
        </div>

        <div class="admin-card">
          <h3>Active Partners</h3>
          <div id="partnerList"></div>
        </div>

        <div class="admin-card">
          <h3>Changelog</h3>
          <ul class="changelog">
            <li><strong>v2.0</strong> — first dynamic Delta build with live weather engine, continuity layer, admin settings, sponsors, bulletins, backup/import, archive/restore, and public/admin separation.</li>
            <li><strong>v2.1</strong> — rebuilt layout hierarchy, live update ticker, full-width Weather Brief above Impact Readout, rotating partner tags on each panel, and partner manager as a standard monetization layer.</li>
            <li><strong>v3.0</strong> — added Today’s Decision Panel under the ticker, introduced a practical interpretation layer with summary, action prompts, best window, commute note, and forecast confidence, and widened the platform canvas for improved balance and readability.</li>
            <li><strong>v3.0e</strong> — moved the platform further left and slightly reduced the overall width to improve visual centering and reduce right-side spill.</li>
            <li><strong>v3.0f</strong> — moved the platform another 10% left and left-aligned the footer version stamp.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-note" id="footerNote">WBN Platform v3.0f | 04-02-26 6:35 pm</div>
</div>

<script>
const ITEMS_KEY = 'platform_items_master';
const SPONSOR_KEY = 'platform_sponsors_master';
const ADMIN_OPEN_KEY = 'platform_admin_master';
const ARCHIVE_KEY = 'platform_archive_master';
const SETTINGS_KEY = 'platform_settings_master';
const META_KEY = 'platform_meta_master';

const LEGACY_ITEMS_KEYS = ['weathercast_items_v1','platform_items_v1'];
const LEGACY_SPONSOR_KEYS = ['weathercast_sponsors_v1','platform_sponsors_v1'];
const LEGACY_ARCHIVE_KEYS = ['weathercast_archive_v1','platform_archive_v1'];
const LEGACY_SETTINGS_KEYS = ['weathercast_settings_v1','platform_settings_v1'];
const LEGACY_META_KEYS = ['weathercast_meta_v1','platform_meta_v1'];

const DEFAULT_SETTINGS = {
  title: 'WeatherCast Terminal™ – Delta',
  subtitle: 'A dedicated city weather intelligence dashboard delivering real-time atmospheric conditions, forecasts, environmental signals, and city impact insights for Delta City.',
  explainer: 'WeatherCast Terminal™ is a live city weather intelligence dashboard built to surface current conditions, forecast shifts, and practical local impact signals in one place—so readers can see what’s happening now and make smarter day-to-day decisions.',
  locationName: 'Delta, BC',
  timezone: 'America/Vancouver',
  latitude: 49.0847,
  longitude: -123.0586,
  windyZoom: 10,
  refreshMinutes: 15,
  forecastUrl: 'https://weather.gc.ca/city/pages/bc-74_metric_e.html',
  alertsUrl: 'https://weather.gc.ca/warnings/index_e.html?prov=bc',
  adminPassword: 'deltaweather'
};

const DEFAULT_META = {
  version: 'v3.0f',
  buildFamily: 'WBN Cast Framework™',
  moduleType: 'WeatherCast Terminal',
  lastEdited: '',
  lastFetchAt: '',
  currentOverlay: 'radar'
};

const DEFAULT_ITEMS = [];
const DEFAULT_SPONSORS = [
  { id: makeId(), name: 'Open Partner Slot', desc: 'Feature your brand inside the Delta WeatherCast.', url: '' }
];

function safeRead(key, fallback = null){
  try{
    const raw = localStorage.getItem(key);
    return raw ? JSON.parse(raw) : fallback;
  }catch{
    return fallback;
  }
}
function safeWrite(key, value){ localStorage.setItem(key, JSON.stringify(value)); }
function migrateFromLegacy(masterKey, legacyKeys, fallback){
  const existing = safeRead(masterKey, null);
  if(existing !== null) return existing;
  for(const legacyKey of legacyKeys){
    const legacyData = safeRead(legacyKey, null);
    if(legacyData !== null){
      safeWrite(masterKey, legacyData);
      return legacyData;
    }
  }
  safeWrite(masterKey, fallback);
  return fallback;
}
function getItems(){ return migrateFromLegacy(ITEMS_KEY, LEGACY_ITEMS_KEYS, DEFAULT_ITEMS); }
function getSponsors(){ return migrateFromLegacy(SPONSOR_KEY, LEGACY_SPONSOR_KEYS, DEFAULT_SPONSORS); }
function getArchive(){ return migrateFromLegacy(ARCHIVE_KEY, LEGACY_ARCHIVE_KEYS, []); }
function getSettings(){
  const settings = migrateFromLegacy(SETTINGS_KEY, LEGACY_SETTINGS_KEYS, DEFAULT_SETTINGS);
  return { ...DEFAULT_SETTINGS, ...settings };
}
function getMeta(){
  const meta = migrateFromLegacy(META_KEY, LEGACY_META_KEYS, DEFAULT_META);
  return { ...DEFAULT_META, ...meta };
}
function setMeta(patch = {}){
  const next = { ...getMeta(), ...patch };
  safeWrite(META_KEY, next);
  return next;
}

let WEATHER_STATE = {
  loading: true,
  error: '',
  current: null,
  hourly: null,
  daily: null,
  micro: [],
  lastFetch: null
};

let refreshTimerId = null;
let countdownIntervalId = null;

function makeId(){ return 'id-' + Math.random().toString(36).slice(2,10) + '-' + Date.now().toString(36); }
function esc(str = ''){
  return String(str)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#39;');
}
function fmtTemp(v){ return (v === null || v === undefined || isNaN(v)) ? '--°C' : `${Math.round(v)}°C`; }
function fmtPct(v){ return (v === null || v === undefined || isNaN(v)) ? '--%' : `${Math.round(v)}%`; }
function fmtKm(v){ return (v === null || v === undefined || isNaN(v)) ? '-- km/h' : `${Math.round(v)} km/h`; }
function fmtMM(v){ return (v === null || v === undefined || isNaN(v)) ? '-- mm' : `${Number(v).toFixed(1)} mm`; }

function fmtTime(dateStr, timezone){
  try{
    return new Intl.DateTimeFormat('en-CA', { hour:'numeric', minute:'2-digit', hour12:true, timeZone:timezone }).format(new Date(dateStr));
  }catch{ return '--'; }
}
function fmtDay(dateStr, timezone){
  try{
    return new Intl.DateTimeFormat('en-CA', { weekday:'short', month:'short', day:'numeric', timeZone:timezone }).format(new Date(dateStr));
  }catch{ return '--'; }
}
function fmtStamp(dateObj, timezone){
  try{
    return new Intl.DateTimeFormat('en-CA', { year:'numeric', month:'short', day:'numeric', hour:'numeric', minute:'2-digit', hour12:true, timeZone:timezone }).format(dateObj);
  }catch{ return '--'; }
}
function windDir(deg){
  if(deg === null || deg === undefined || isNaN(deg)) return '--';
  const dirs = ['N','NE','E','SE','S','SW','W','NW'];
  return dirs[Math.round(deg / 45) % 8];
}
function clamp(num, min, max){ return Math.max(min, Math.min(max, num)); }
function avgFirstHours(arr, count, fallback = 0){
  if(!Array.isArray(arr) || !arr.length) return fallback;
  const subset = arr.slice(0, count);
  const sum = subset.reduce((a,b) => a + (Number(b) || 0), 0);
  return sum / subset.length;
}
function weatherCodeToText(code){
  const map = {
    0:'Clear',1:'Mainly clear',2:'Partly cloudy',3:'Cloudy',45:'Fog',48:'Depositing rime fog',
    51:'Light drizzle',53:'Drizzle',55:'Dense drizzle',56:'Freezing drizzle',57:'Dense freezing drizzle',
    61:'Light rain',63:'Rain',65:'Heavy rain',66:'Freezing rain',67:'Heavy freezing rain',
    71:'Light snow',73:'Snow',75:'Heavy snow',77:'Snow grains',
    80:'Rain showers',81:'Rain showers',82:'Heavy showers',
    85:'Snow showers',86:'Heavy snow showers',
    95:'Thunderstorm',96:'Thunderstorm with hail',99:'Severe thunderstorm'
  };
  return map[code] || 'Conditions changing';
}
function getClassForLevel(level){
  if(level === 'bad') return 'tag-bad';
  if(level === 'warn') return 'tag-warn';
  return 'tag-good';
}
function getLabelForLevel(level){
  if(level === 'bad') return 'Warning';
  if(level === 'warn') return 'Advisory';
  return 'Monitoring';
}
function scoreClass(value){
  if(typeof value === 'string') return '';
  if(value >= 8) return 'score-good';
  if(value >= 5) return 'score-warn';
  return 'score-bad';
}
function setText(id, value){
  const el = document.getElementById(id);
  if(el) el.textContent = value;
}
function setHTML(id, value){
  const el = document.getElementById(id);
  if(el) el.innerHTML = value;
}

const PARTNER_TARGETS = ['conditions','brief','impact','timeline','map','forecast','alerts','micro','partner'];

function renderPartnerTags(){
  const sponsors = getSponsors();
  PARTNER_TARGETS.forEach((key, idx) => {
    const el = document.getElementById('tag-' + key);
    if(!el) return;
    if(!sponsors.length){ el.textContent = ''; return; }
    const sponsor = sponsors[idx % sponsors.length];
    if(!sponsor || !sponsor.name){ el.textContent = ''; return; }
    const label = sponsor.url
      ? `Partner: <a href="${esc(sponsor.url)}" target="_blank" rel="noopener">${esc(sponsor.name)}</a>`
      : `Partner: ${esc(sponsor.name)}`;
    el.innerHTML = label;
  });
}

function renderPartnerSpotlight(){
  const wrap = document.getElementById('partnerGrid');
  const sponsors = getSponsors();
  if(!sponsors.length){
    wrap.innerHTML = `<div class="partner-card"><h3>Open Partner Slot</h3><p class="muted">Add partner cards from the admin console.</p></div>`;
    return;
  }
  wrap.innerHTML = sponsors.map(s => `
    <div class="partner-card">
      <h3>${esc(s.name)}</h3>
      <p class="muted">${esc(s.desc || '')}</p>
      ${s.url ? `<a class="btn secondary" href="${esc(s.url)}" target="_blank" rel="noopener">Visit Partner</a>` : ''}
    </div>
  `).join('');
}

function buildForecastUrl(lat, lon, timezone){
  const params = new URLSearchParams({
    latitude: lat,
    longitude: lon,
    timezone,
    current: ['temperature_2m','apparent_temperature','relative_humidity_2m','precipitation','precipitation_probability','weather_code','wind_speed_10m','wind_direction_10m','is_day'].join(','),
    hourly: ['temperature_2m','apparent_temperature','relative_humidity_2m','precipitation_probability','precipitation','weather_code','wind_speed_10m','wind_direction_10m','uv_index','visibility'].join(','),
    daily: ['weather_code','temperature_2m_max','temperature_2m_min','precipitation_sum','precipitation_probability_max','sunrise','sunset','wind_speed_10m_max','uv_index_max'].join(','),
    forecast_days: 7
  });
  return 'https://api.open-meteo.com/v1/forecast?' + params.toString();
}
function buildCurrentOnlyUrl(lat, lon, timezone){
  const params = new URLSearchParams({
    latitude: lat,
    longitude: lon,
    timezone,
    current: ['temperature_2m','weather_code','wind_speed_10m','relative_humidity_2m'].join(',')
  });
  return 'https://api.open-meteo.com/v1/forecast?' + params.toString();
}

function overlayToWindy(overlay){
  const map = { radar:'radar', satellite:'satellite', wind:'wind', clouds:'clouds', rain:'rain', temp:'temp' };
  return map[overlay] || 'radar';
}
function updateWindyMap(overlay){
  const settings = getSettings();
  const lat = settings.latitude;
  const lon = settings.longitude;
  const zoom = settings.windyZoom || 10;
  const windyOverlay = overlayToWindy(overlay);
  const src = `https://embed.windy.com/embed2.html?lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lon)}&detailLat=${encodeURIComponent(lat)}&detailLon=${encodeURIComponent(lon)}&width=100%25&height=520&zoom=${encodeURIComponent(zoom)}&level=surface&overlay=${encodeURIComponent(windyOverlay)}&product=ecmwf&menu=&message=true&marker=true&calendar=now&pressure=true&type=map&location=coordinates&detail=true&metricWind=km%2Fh&metricTemp=%C2%B0C`;
  document.getElementById('windyFrame').src = src;

  const statusMap = {
    radar:'Radar view active.',
    satellite:'Satellite view active.',
    wind:'Wind overlay active.',
    clouds:'Cloud cover overlay active.',
    rain:'Rain overlay active.',
    temp:'Temperature overlay active.'
  };
  setText('mapStatus', statusMap[overlay] || 'Map active.');
  setMeta({ currentOverlay: overlay });

  document.querySelectorAll('.tab-btn').forEach(btn => {
    const isActive = btn.dataset.overlay === overlay;
    btn.classList.toggle('active', isActive);
    btn.classList.toggle('secondary', !isActive);
  });
}

async function fetchMainWeather(){
  const settings = getSettings();
  const url = buildForecastUrl(settings.latitude, settings.longitude, settings.timezone);
  const res = await fetch(url);
  if(!res.ok) throw new Error('Weather fetch failed');
  return await res.json();
}
async function fetchMicroClimate(point){
  const settings = getSettings();
  const url = buildCurrentOnlyUrl(point.lat, point.lon, settings.timezone);
  const res = await fetch(url);
  if(!res.ok) throw new Error('Microclimate fetch failed');
  const json = await res.json();
  return { ...point, data: json.current || null };
}

async function loadWeatherData(showLoading = false){
  if(showLoading){
    WEATHER_STATE.loading = true;
    WEATHER_STATE.error = '';
    renderAll();
  }

  try{
    const microPoints = [
      { name:'North Delta', lat:49.1435, lon:-122.8927 },
      { name:'Ladner', lat:49.0890, lon:-123.0824 },
      { name:'Tsawwassen', lat:49.0249, lon:-123.0677 },
      { name:'Boundary Bay', lat:49.0430, lon:-123.1400 }
    ];

    const [main, ...micro] = await Promise.all([
      fetchMainWeather(),
      ...microPoints.map(fetchMicroClimate)
    ]);

    WEATHER_STATE = {
      loading:false,
      error:'',
      current:main.current || null,
      hourly:main.hourly || null,
      daily:main.daily || null,
      micro:micro,
      lastFetch:new Date()
    };

    setMeta({ lastFetchAt: WEATHER_STATE.lastFetch.toISOString() });
    renderAll();
    scheduleRefresh();
  }catch(err){
    WEATHER_STATE.loading = false;
    WEATHER_STATE.error = 'Unable to load live weather data.';
    renderAll();
    scheduleRefresh();
  }
}

function getTodayIndices(hourly){
  if(!hourly || !hourly.time) return [];
  const settings = getSettings();
  const todayKey = new Intl.DateTimeFormat('sv-SE', { timeZone: settings.timezone, year:'numeric', month:'2-digit', day:'2-digit' }).format(new Date());
  const indices = [];
  hourly.time.forEach((t, idx) => {
    const key = new Intl.DateTimeFormat('sv-SE', { timeZone: settings.timezone, year:'numeric', month:'2-digit', day:'2-digit' }).format(new Date(t));
    if(key === todayKey) indices.push(idx);
  });
  return indices;
}

function buildWeatherBrief(){
  const current = WEATHER_STATE.current;
  const daily = WEATHER_STATE.daily;
  const hourly = WEATHER_STATE.hourly;
  if(!current || !daily || !hourly) return 'Loading forecast summary…';

  const high = daily.temperature_2m_max?.[0];
  const low = daily.temperature_2m_min?.[0];
  const rainProb = daily.precipitation_probability_max?.[0] ?? 0;
  const rainSum = daily.precipitation_sum?.[0] ?? 0;
  const maxWind = daily.wind_speed_10m_max?.[0] ?? 0;
  const cond = weatherCodeToText(current.weather_code);
  const todayIndices = getTodayIndices(hourly);
  const dryHours = todayIndices.filter(i => (hourly.precipitation_probability?.[i] ?? 0) < 25).length;
  const strongWind = maxWind >= 35;
  const wetDay = rainProb >= 60 || rainSum >= 3;
  const mildDay = (high ?? 0) >= 11 && (high ?? 0) <= 18;

  let lead = `Delta is tracking ${cond.toLowerCase()} conditions right now at ${fmtTemp(current.temperature_2m)}. `;
  let body = `Today looks like a ${wetDay ? 'higher-moisture' : 'fairly manageable'} pattern with a high near ${Math.round(high)}°C and a low around ${Math.round(low)}°C. `;
  let impact = wetDay ? `Keep an eye on rain timing, especially for commuting, field work, and outdoor plans. ` : `There should be workable outdoor windows through much of the day. `;
  let wind = strongWind ? `Winds may become a factor, particularly near open roads and waterfront areas. ` : `Wind is not the main disruption factor today. `;
  let finish = dryHours >= 5 ? `Overall, Delta gets several usable hours for errands, site visits, and local events.` : `Overall, the day looks more stop-and-start, with fewer clean outdoor windows than usual.`;
  if(mildDay && !wetDay){
    finish = `Overall, this is one of the better Delta weather days for outdoor activity, neighbourhood traffic, and event readiness.`;
  }
  return lead + body + impact + wind + finish;
}

function autoRiskReadout(){
  const daily = WEATHER_STATE.daily;
  const current = WEATHER_STATE.current;
  if(!daily || !current){
    return {
      level:'good',
      label:'Monitoring',
      text:'Forecast thresholds are still loading.',
      meta:'Rain, wind, and temperature triggers will appear here.'
    };
  }

  const rainProb = daily.precipitation_probability_max?.[0] ?? 0;
  const rainSum = daily.precipitation_sum?.[0] ?? 0;
  const maxWind = daily.wind_speed_10m_max?.[0] ?? 0;
  const currentCode = current.weather_code;

  if(maxWind >= 55 || rainSum >= 15 || [95,96,99].includes(currentCode)){
    return {
      level:'bad',
      label:'Warning',
      text:'Weather disruption risk is elevated for Delta today. Strong wind, heavy rain, or storm instability could affect travel, waterfront exposure, and outdoor operations.',
      meta:'High-impact thresholds triggered by wind, rainfall, or storm code.'
    };
  }

  if(maxWind >= 35 || rainProb >= 70 || rainSum >= 5){
    return {
      level:'warn',
      label:'Advisory',
      text:'Conditions deserve extra attention today. Expect a more uneven operating day for commutes, job sites, and outdoor plans in exposed parts of Delta.',
      meta:'Moderate thresholds triggered by rain probability, rainfall totals, or wind.'
    };
  }

  return {
    level:'good',
    label:'Monitoring',
    text:'No major automated weather trigger is showing right now for Delta. Normal local caution still applies, especially near the water.',
    meta:'No significant rain or wind threshold triggered at the moment.'
  };
}

function computeScores(){
  const current = WEATHER_STATE.current;
  const daily = WEATHER_STATE.daily;

  if(!current || !daily){
    return {
      commute:{value:'Loading…', text:'Assessing rain, visibility, and wind.'},
      outdoor:{value:'Loading…', text:'Checking comfort and dry windows.'},
      marine:{value:'Loading…', text:'Looking at wind and coastal exposure.'},
      air:{value:'Watch', text:'Local AQI feed can be layered in later.'},
      event:{value:'Loading…', text:'Checking rain timing and temperature.'},
      build:{value:'Loading…', text:'Watching rain and wind disruption risk.'}
    };
  }

  const rainProb = daily.precipitation_probability_max?.[0] ?? 0;
  const rainSum = daily.precipitation_sum?.[0] ?? 0;
  const maxWind = daily.wind_speed_10m_max?.[0] ?? 0;
  const high = daily.temperature_2m_max?.[0] ?? 0;
  const visibility = avgFirstHours(WEATHER_STATE.hourly?.visibility, 6, 10000);
  const comfortPenalty = Math.abs(15 - high);

  let commuteScore = 10 - (rainProb / 20) - (maxWind / 25) - (visibility < 5000 ? 2 : 0);
  let outdoorScore = 10 - (rainProb / 18) - (rainSum / 3) - (comfortPenalty / 8);
  let marineScore = 10 - (maxWind / 10) - (rainProb / 30);
  let eventScore = 10 - (rainProb / 16) - (rainSum / 4) - (maxWind / 28);
  let buildScore = 10 - (rainProb / 16) - (rainSum / 3) - (maxWind / 22);

  commuteScore = clamp(Math.round(commuteScore), 1, 10);
  outdoorScore = clamp(Math.round(outdoorScore), 1, 10);
  marineScore = clamp(Math.round(marineScore), 1, 10);
  eventScore = clamp(Math.round(eventScore), 1, 10);
  buildScore = clamp(Math.round(buildScore), 1, 10);

  return {
    commute:{ value:commuteScore + '/10', text:commuteScore >= 8 ? 'Low disruption risk for most local routes.' : commuteScore >= 5 ? 'Some slowdown risk from rain or wind.' : 'Higher travel friction likely in exposed or busy corridors.', numeric: commuteScore },
    outdoor:{ value:outdoorScore + '/10', text:outdoorScore >= 8 ? 'Good day for general outdoor use.' : outdoorScore >= 5 ? 'Usable with timing and backup plans.' : 'More limited outdoor value today.', numeric: outdoorScore },
    marine:{ value:marineScore + '/10', text:marineScore >= 8 ? 'Relatively manageable near-coastal conditions.' : marineScore >= 5 ? 'Waterfront caution advised.' : 'Coastal exposure risk is elevated.', numeric: marineScore },
    air:{ value:'Watch', text:'Add AQHI integration later for full smoke and pollution monitoring.' },
    event:{ value:eventScore + '/10', text:eventScore >= 8 ? 'Good readiness for local events.' : eventScore >= 5 ? 'Moderate planning caution recommended.' : 'Indoor backup or stronger planning advised.', numeric: eventScore },
    build:{ value:buildScore + '/10', text:buildScore >= 8 ? 'Field conditions look workable.' : buildScore >= 5 ? 'Possible weather drag on outdoor work.' : 'Weather could materially slow site activity.', numeric: buildScore }
  };
}

function buildTickerItems(){
  const items = [];
  const current = WEATHER_STATE.current;
  const daily = WEATHER_STATE.daily;
  const scores = computeScores();
  const bulletins = getItems();

  if(current){
    items.push(`${weatherCodeToText(current.weather_code)} now in Delta at ${fmtTemp(current.temperature_2m)}`);
    items.push(`Wind ${fmtKm(current.wind_speed_10m)} from ${windDir(current.wind_direction_10m)}`);
  }

  if(daily){
    items.push(`Rain risk today ${fmtPct(daily.precipitation_probability_max?.[0] ?? 0)}`);
    items.push(`High / Low ${Math.round(daily.temperature_2m_max?.[0] ?? 0)}° / ${Math.round(daily.temperature_2m_min?.[0] ?? 0)}°`);
    items.push(`Precipitation today ${fmtMM(daily.precipitation_sum?.[0] ?? 0)}`);
  }

  if(scores.outdoor?.value) items.push(`Outdoor score ${scores.outdoor.value}`);
  if(scores.commute?.value) items.push(`Commute ${scores.commute.value}`);
  if(scores.event?.value) items.push(`Event readiness ${scores.event.value}`);

  if(bulletins.length){
    const top = bulletins[0];
    items.unshift(`${getLabelForLevel(top.level)}: ${top.title}`);
  }

  const deduped = [...new Set(items.filter(Boolean))];
  return deduped.length ? deduped : ['Live Delta weather update is loading…'];
}

function getNext8TodayPoints(){
  const hourly = WEATHER_STATE.hourly;
  if(!hourly || !hourly.time) return [];
  const settings = getSettings();
  const todayIndices = getTodayIndices(hourly);
  const now = new Date();
  const points = [];

  for(const i of todayIndices){
    const t = new Date(hourly.time[i]);
    if(t >= now && points.length < 8){
      points.push({
        index: i,
        time: hourly.time[i],
        temp: hourly.temperature_2m?.[i],
        pop: hourly.precipitation_probability?.[i] ?? 0,
        code: hourly.weather_code?.[i],
        wind: hourly.wind_speed_10m?.[i] ?? 0,
        label: fmtTime(hourly.time[i], settings.timezone)
      });
    }
  }

  return points;
}

function buildDecisionData(){
  const current = WEATHER_STATE.current;
  const daily = WEATHER_STATE.daily;
  const hourly = WEATHER_STATE.hourly;

  if(!current || !daily || !hourly){
    return {
      lead:'Generating today’s decision summary…',
      actions:['Loading daily guidance…'],
      bestWindow:'Checking the best time to be outside…',
      commute:'Assessing likely travel friction…',
      confidence:'Calculating forecast confidence…'
    };
  }

  const points = getNext8TodayPoints();
  const rainProb = daily.precipitation_probability_max?.[0] ?? 0;
  const rainSum = daily.precipitation_sum?.[0] ?? 0;
  const maxWind = daily.wind_speed_10m_max?.[0] ?? 0;
  const high = daily.temperature_2m_max?.[0] ?? 0;
  const low = daily.temperature_2m_min?.[0] ?? 0;
  const nowCond = weatherCodeToText(current.weather_code).toLowerCase();

  const actions = [];

  if(current.temperature_2m < 14){
    actions.push('Bring a light jacket or outer layer for the cooler part of the day.');
  } else if(current.temperature_2m > 24){
    actions.push('Dress lighter and plan hydration if you will be outside for longer stretches.');
  } else {
    actions.push('Conditions are fairly manageable for normal day-to-day activity.');
  }

  if(rainProb >= 60 || rainSum >= 3){
    actions.push('Keep an umbrella or rain layer nearby in case showers arrive earlier than expected.');
  } else if(rainProb >= 35){
    actions.push('A flexible backup plan is smart if you have outdoor errands or appointments.');
  } else {
    actions.push('Outdoor plans look more workable than usual with fewer weather interruptions expected.');
  }

  if(maxWind >= 35){
    actions.push('Use extra caution on exposed roads, near the water, and around unsecured outdoor items.');
  }

  if(high >= 11 && high <= 18 && rainProb < 50){
    actions.push('This is a relatively good day for errands, walks, and general outdoor use if you time it well.');
  }

  const goodWindowPoints = points.filter(p => p.pop < 35 && p.wind < 28);
  let bestWindow = 'Usable time blocks are still being calculated.';
  if(goodWindowPoints.length){
    bestWindow = `Best outdoor window: ${goodWindowPoints[0].label} to ${goodWindowPoints[goodWindowPoints.length - 1].label}.`;
  } else if(points.length){
    bestWindow = `Outdoor timing looks more limited today. The cleanest window appears closest to ${points[0].label}.`;
  }

  const laterWet = points.find(p => p.pop >= 55 || p.code === 61 || p.code === 63 || p.code === 65 || p.code === 80 || p.code === 81 || p.code === 82);
  const eveningPoint = points[Math.min(points.length - 1, Math.max(0, points.length - 2))];
  let commute = 'Commute conditions look fairly routine right now.';
  if(laterWet){
    commute = `Watch the commute after ${laterWet.label} — rain or heavier moisture may slow local travel.`;
  } else if(eveningPoint && eveningPoint.wind >= 30){
    commute = `Later travel looks breezier than usual, especially in exposed corridors.`;
  } else if(rainProb >= 40){
    commute = 'Travel disruption risk looks moderate today, so a little extra time is sensible.';
  }

  let confidence = 'Forecast confidence: High — pattern looks fairly stable today.';
  if(rainProb >= 40 || maxWind >= 30){
    confidence = 'Forecast confidence: Moderate — timing and intensity may shift through the day.';
  }
  if(rainProb >= 70 && maxWind >= 35){
    confidence = 'Forecast confidence: Moderate to lower — conditions may evolve more unevenly than the early forecast suggests.';
  }

  let lead = `Right now Delta is seeing ${nowCond} conditions at ${fmtTemp(current.temperature_2m)}, with a day trending toward a high near ${Math.round(high)}°C and a low around ${Math.round(low)}°C.`;
  if(rainProb >= 60){
    lead = `Delta starts with ${nowCond} conditions at ${fmtTemp(current.temperature_2m)}, but later rain risk is elevated enough that timing your day will matter.`;
  } else if(maxWind >= 35){
    lead = `Delta is running ${nowCond} at ${fmtTemp(current.temperature_2m)}, with wind likely to become a more noticeable factor later on.`;
  } else if(high >= 11 && high <= 18 && rainProb < 40){
    lead = `Delta is off to a workable start at ${fmtTemp(current.temperature_2m)}, and today looks fairly usable for normal outdoor plans if you take advantage of the better window.`;
  }

  return { lead, actions, bestWindow, commute, confidence };
}

function renderHeader(){
  const settings = getSettings();
  const meta = getMeta();
  setText('heroTitle', settings.title);
  setText('heroSubtitle', settings.subtitle);
  setText('explainerText', settings.explainer);
  setText('sourceStamp', 'Source: Open-Meteo + Windy');
  setText('footerNote', `WBN Platform ${meta.version} | 04-02-26 6:35 pm`);

  const updated = WEATHER_STATE.lastFetch
    ? `Updated: ${fmtStamp(WEATHER_STATE.lastFetch, settings.timezone)}`
    : 'Updated: --';

  setText('updatedStamp', updated);
  document.getElementById('ecForecastLink').href = settings.forecastUrl || '#';
  document.getElementById('ecAlertsLink').href = settings.alertsUrl || '#';
  const tickerText = buildTickerItems().join('  •  ') + '  •  ';
  setText('tickerTrack', tickerText);
}

function renderDecisionPanel(){
  const decision = buildDecisionData();
  setText('decisionLead', decision.lead);
  setHTML('decisionActions', decision.actions.map(item => `<li>${esc(item)}</li>`).join(''));
  setText('decisionWindow', decision.bestWindow);
  setText('decisionCommute', decision.commute);
  setText('decisionConfidence', decision.confidence);
}

function renderCurrentView(){
  if(WEATHER_STATE.error){
    setText('conditionNow', WEATHER_STATE.error);
    return;
  }

  const current = WEATHER_STATE.current;
  const daily = WEATHER_STATE.daily;
  const settings = getSettings();
  if(!current || !daily) return;

  setText('tempNow', fmtTemp(current.temperature_2m));
  setText('conditionNow', weatherCodeToText(current.weather_code));
  setText('feelsNow', fmtTemp(current.apparent_temperature));
  setText('humidityNow', `Humidity ${fmtPct(current.relative_humidity_2m)}`);
  setText('windNow', fmtKm(current.wind_speed_10m));
  setText('windDirNow', `Direction ${windDir(current.wind_direction_10m)}`);
  setText('rainRiskNow', fmtPct(current.precipitation_probability ?? daily.precipitation_probability_max?.[0]));
  setText('highLowNow', `High / Low ${Math.round(daily.temperature_2m_max?.[0] ?? 0)}° / ${Math.round(daily.temperature_2m_min?.[0] ?? 0)}°`);
  setText('weatherBrief', buildWeatherBrief());
  setText('sunNow', `${fmtTime(daily.sunrise?.[0], settings.timezone)} / ${fmtTime(daily.sunset?.[0], settings.timezone)}`);
  setText('uvPeak', String(Math.round(daily.uv_index_max?.[0] ?? 0)));
  setText('precipToday', fmtMM(daily.precipitation_sum?.[0] ?? 0));
}

function renderImpactScores(){
  const scores = computeScores();
  setText('scoreCommute', scores.commute.value);
  setText('textCommute', scores.commute.text);
  document.getElementById('scoreCommute').className = 'impact-score ' + scoreClass(scores.commute.numeric);

  setText('scoreOutdoor', scores.outdoor.value);
  setText('textOutdoor', scores.outdoor.text);
  document.getElementById('scoreOutdoor').className = 'impact-score ' + scoreClass(scores.outdoor.numeric);

  setText('scoreMarine', scores.marine.value);
  setText('textMarine', scores.marine.text);
  document.getElementById('scoreMarine').className = 'impact-score ' + scoreClass(scores.marine.numeric);

  setText('scoreAir', scores.air.value);
  setText('textAir', scores.air.text);
  document.getElementById('scoreAir').className = 'impact-score score-warn';

  setText('scoreEvent', scores.event.value);
  setText('textEvent', scores.event.text);
  document.getElementById('scoreEvent').className = 'impact-score ' + scoreClass(scores.event.numeric);

  setText('scoreBuild', scores.build.value);
  setText('textBuild', scores.build.text);
  document.getElementById('scoreBuild').className = 'impact-score ' + scoreClass(scores.build.numeric);
}

function renderTimeline(){
  const wrap = document.getElementById('timelineWrap');
  const hourly = WEATHER_STATE.hourly;
  if(!hourly || !hourly.time){
    wrap.innerHTML = '<div class="timeline-item loader">Loading timeline…</div>';
    return;
  }

  const settings = getSettings();
  const now = new Date();
  const points = [];

  for(let i = 0; i < hourly.time.length; i++){
    const t = new Date(hourly.time[i]);
    if(t >= now && points.length < 8){
      points.push({
        time: hourly.time[i],
        temp: hourly.temperature_2m?.[i],
        pop: hourly.precipitation_probability?.[i],
        code: hourly.weather_code?.[i],
        wind: hourly.wind_speed_10m?.[i]
      });
    }
  }

  wrap.innerHTML = points.map(p => `
    <div class="timeline-item">
      <div class="small">${esc(fmtTime(p.time, settings.timezone))}</div>
      <div style="font-size:20px;font-weight:800;margin:6px 0;">${esc(fmtTemp(p.temp))}</div>
      <div class="tiny">${esc(weatherCodeToText(p.code))}</div>
      <div class="tiny" style="margin-top:8px;">Rain ${esc(fmtPct(p.pop))}</div>
      <div class="tiny">Wind ${esc(fmtKm(p.wind))}</div>
    </div>
  `).join('');
}

function renderForecast(){
  const wrap = document.getElementById('forecastWrap');
  const daily = WEATHER_STATE.daily;
  const settings = getSettings();
  if(!daily || !daily.time){
    wrap.innerHTML = '<div class="forecast-day loader">Loading 7-day forecast…</div>';
    return;
  }

  wrap.innerHTML = daily.time.map((dateStr, idx) => {
    const code = daily.weather_code?.[idx];
    const high = daily.temperature_2m_max?.[idx];
    const low = daily.temperature_2m_min?.[idx];
    const rain = daily.precipitation_probability_max?.[idx];
    const rainSum = daily.precipitation_sum?.[idx];
    const wind = daily.wind_speed_10m_max?.[idx];

    return `
      <div class="forecast-day">
        <div class="day">${esc(fmtDay(dateStr, settings.timezone))}</div>
        <div class="tiny">${esc(weatherCodeToText(code))}</div>
        <div class="temps">${Math.round(high)}° / ${Math.round(low)}°</div>
        <div class="tiny">Rain risk ${esc(fmtPct(rain))}</div>
        <div class="tiny">Rain ${esc(fmtMM(rainSum))}</div>
        <div class="tiny">Wind max ${esc(fmtKm(wind))}</div>
      </div>
    `;
  }).join('');
}

function renderAlerts(){
  const auto = autoRiskReadout();
  const activeBulletins = getItems();
  const autoTag = document.getElementById('autoAlertTag');
  autoTag.className = 'alert-tag ' + getClassForLevel(auto.level);
  autoTag.textContent = auto.label;
  setText('autoAlertText', auto.text);
  setText('autoAlertMeta', auto.meta);

  const manualTag = document.getElementById('manualAlertTag');
  const manualText = document.getElementById('manualAlertText');

  if(activeBulletins.length){
    const top = activeBulletins[0];
    manualTag.className = 'alert-tag ' + getClassForLevel(top.level);
    manualTag.textContent = getLabelForLevel(top.level);
    manualText.textContent = `${top.title}: ${top.text}`;
  }else{
    manualTag.className = 'alert-tag tag-good';
    manualTag.textContent = 'Official Links Ready';
    manualText.textContent = 'Use the buttons below to open official forecast sources or post a local admin bulletin.';
  }
}

function renderMicroclimates(){
  const wrap = document.getElementById('microWrap');
  if(!WEATHER_STATE.micro || !WEATHER_STATE.micro.length){
    wrap.innerHTML = '<div class="micro-card loader">Loading neighbourhood conditions…</div>';
    return;
  }

  wrap.innerHTML = WEATHER_STATE.micro.map(point => {
    const d = point.data || {};
    return `
      <div class="micro-card">
        <h3>${esc(point.name)}</h3>
        <div style="font-size:24px;font-weight:800;margin:8px 0;">${esc(fmtTemp(d.temperature_2m))}</div>
        <div class="tiny">${esc(weatherCodeToText(d.weather_code))}</div>
        <div class="tiny" style="margin-top:8px;">Wind ${esc(fmtKm(d.wind_speed_10m))}</div>
        <div class="tiny">Humidity ${esc(fmtPct(d.relative_humidity_2m))}</div>
      </div>
    `;
  }).join('');
}

function renderAdminView(){
  const settings = getSettings();
  const isOpen = safeRead(ADMIN_OPEN_KEY, false);
  document.getElementById('adminShell').classList.toggle('open', !!isOpen);

  document.getElementById('setTitle').value = settings.title;
  document.getElementById('setSubtitle').value = settings.subtitle;
  document.getElementById('setExplainer').value = settings.explainer;
  document.getElementById('setLocationName').value = settings.locationName;
  document.getElementById('setTimezone').value = settings.timezone;
  document.getElementById('setLat').value = settings.latitude;
  document.getElementById('setLon').value = settings.longitude;
  document.getElementById('setZoom').value = settings.windyZoom;
  document.getElementById('setRefresh').value = settings.refreshMinutes;
  document.getElementById('setForecastUrl').value = settings.forecastUrl;
  document.getElementById('setAlertsUrl').value = settings.alertsUrl;
  document.getElementById('setAdminPassword').value = settings.adminPassword;

  const bulletins = getItems();
  const archive = getArchive();
  const partners = getSponsors();

  setHTML('bulletinList', bulletins.length ? bulletins.map((item, idx) => `
    <div class="list-row">
      <div><strong>${esc(item.title)}</strong></div>
      <div class="tiny">${esc(getLabelForLevel(item.level))} • ${esc(item.scope || 'All Delta')}</div>
      <p class="muted" style="margin:8px 0;">${esc(item.text)}</p>
      <div class="row-actions">
        <button class="mini-btn secondary" onclick="moveItemUp(${idx})">Move Up</button>
        <button class="mini-btn secondary" onclick="moveItemDown(${idx})">Move Down</button>
        <button class="mini-btn secondary" onclick="editBulletin('${item.id}')">Edit</button>
        <button class="mini-btn secondary" onclick="archiveBulletin('${item.id}')">Archive</button>
        <button class="mini-btn secondary" onclick="deleteBulletin('${item.id}')">Delete</button>
      </div>
    </div>
  `).join('') : '<div class="small">No active bulletins.</div>');

  setHTML('archiveList', archive.length ? archive.map(item => `
    <div class="list-row">
      <div><strong>${esc(item.title)}</strong></div>
      <div class="tiny">${esc(getLabelForLevel(item.level))} • ${esc(item.scope || 'All Delta')}</div>
      <p class="muted" style="margin:8px 0;">${esc(item.text)}</p>
      <div class="row-actions">
        <button class="mini-btn secondary" onclick="restoreBulletin('${item.id}')">Restore</button>
        <button class="mini-btn secondary" onclick="deleteArchivedBulletin('${item.id}')">Delete</button>
      </div>
    </div>
  `).join('') : '<div class="small">No archived bulletins.</div>');

  setHTML('partnerList', partners.length ? partners.map((p, idx) => `
    <div class="list-row">
      <div><strong>${esc(p.name)}</strong></div>
      <p class="muted" style="margin:8px 0;">${esc(p.desc || '')}</p>
      <div class="tiny">${esc(p.url || 'No URL')}</div>
      <div class="row-actions">
        <button class="mini-btn secondary" onclick="movePartnerUp(${idx})">Move Up</button>
        <button class="mini-btn secondary" onclick="movePartnerDown(${idx})">Move Down</button>
        <button class="mini-btn secondary" onclick="editPartner('${p.id}')">Edit</button>
        <button class="mini-btn secondary" onclick="deletePartner('${p.id}')">Delete</button>
      </div>
    </div>
  `).join('') : '<div class="small">No partners yet.</div>');
}

function renderAll(){
  renderHeader();
  renderDecisionPanel();
  renderCurrentView();
  renderImpactScores();
  renderTimeline();
  renderForecast();
  renderAlerts();
  renderMicroclimates();
  renderPartnerTags();
  renderPartnerSpotlight();
  renderAdminView();
  const meta = getMeta();
  updateWindyMap(meta.currentOverlay || 'radar');
}

function addBulletin(){
  const title = document.getElementById('bulletinTitle').value.trim();
  const text = document.getElementById('bulletinText').value.trim();
  const level = document.getElementById('bulletinLevel').value;
  const scope = document.getElementById('bulletinScope').value.trim();
  if(!title || !text){ alert('Add both bulletin title and bulletin copy.'); return; }

  const items = getItems();
  items.unshift({ id: makeId(), title, text, level, scope, createdAt: new Date().toISOString() });
  safeWrite(ITEMS_KEY, items);
  setMeta({ lastEdited: new Date().toISOString() });

  document.getElementById('bulletinTitle').value = '';
  document.getElementById('bulletinText').value = '';
  document.getElementById('bulletinScope').value = '';
  document.getElementById('bulletinLevel').value = 'good';
  renderAll();
}

function editBulletin(id){
  const items = getItems();
  const item = items.find(x => x.id === id);
  if(!item) return;
  const newTitle = prompt('Edit bulletin title:', item.title);
  if(newTitle === null) return;
  const newText = prompt('Edit bulletin copy:', item.text);
  if(newText === null) return;
  const newScope = prompt('Edit bulletin scope:', item.scope || '');
  if(newScope === null) return;
  const newLevel = prompt('Edit level: good / warn / bad', item.level);
  if(newLevel === null) return;

  item.title = newTitle.trim() || item.title;
  item.text = newText.trim() || item.text;
  item.scope = newScope.trim();
  item.level = ['good','warn','bad'].includes(newLevel.trim()) ? newLevel.trim() : item.level;
  safeWrite(ITEMS_KEY, items);
  setMeta({ lastEdited: new Date().toISOString() });
  renderAll();
}

function deleteBulletin(id){
  safeWrite(ITEMS_KEY, getItems().filter(x => x.id !== id));
  setMeta({ lastEdited: new Date().toISOString() });
  renderAll();
}

function archiveBulletin(id){
  const items = getItems();
  const archive = getArchive();
  const idx = items.findIndex(x => x.id === id);
  if(idx === -1) return;
  const [item] = items.splice(idx, 1);
  archive.unshift(item);
  safeWrite(ITEMS_KEY, items);
  safeWrite(ARCHIVE_KEY, archive);
  setMeta({ lastEdited: new Date().toISOString() });
  renderAll();
}

function restoreBulletin(id){
  const items = getItems();
  const archive = getArchive();
  const idx = archive.findIndex(x => x.id === id);
  if(idx === -1) return;
  const [item] = archive.splice(idx, 1);
  items.unshift(item);
  safeWrite(ITEMS_KEY, items);
  safeWrite(ARCHIVE_KEY, archive);
  setMeta({ lastEdited: new Date().toISOString() });
  renderAll();
}

function deleteArchivedBulletin(id){
  safeWrite(ARCHIVE_KEY, getArchive().filter(x => x.id !== id));
  setMeta({ lastEdited: new Date().toISOString() });
  renderAll();
}

function moveItemUp(index){
  const items = getItems();
  if(index <= 0) return;
  [items[index - 1], items[index]] = [items[index], items[index - 1]];
  safeWrite(ITEMS_KEY, items);
  renderAll();
}

function moveItemDown(index){
  const items = getItems();
  if(index >= items.length - 1) return;
  [items[index + 1], items[index]] = [items[index], items[index + 1]];
  safeWrite(ITEMS_KEY, items);
  renderAll();
}

function addPartner(){
  const name = document.getElementById('partnerName').value.trim();
  const desc = document.getElementById('partnerDesc').value.trim();
  const url = document.getElementById('partnerUrl').value.trim();
  if(!name){ alert('Add partner name.'); return; }
  const partners = getSponsors();
  partners.push({ id: makeId(), name, desc, url });
  safeWrite(SPONSOR_KEY, partners);
  setMeta({ lastEdited: new Date().toISOString() });
  document.getElementById('partnerName').value = '';
  document.getElementById('partnerDesc').value = '';
  document.getElementById('partnerUrl').value = '';
  renderAll();
}

function editPartner(id){
  const partners = getSponsors();
  const item = partners.find(x => x.id === id);
  if(!item) return;
  const newName = prompt('Edit partner name:', item.name);
  if(newName === null) return;
  const newDesc = prompt('Edit partner description:', item.desc || '');
  if(newDesc === null) return;
  const newUrl = prompt('Edit partner URL:', item.url || '');
  if(newUrl === null) return;

  item.name = newName.trim() || item.name;
  item.desc = newDesc.trim();
  item.url = newUrl.trim();
  safeWrite(SPONSOR_KEY, partners);
  setMeta({ lastEdited: new Date().toISOString() });
  renderAll();
}

function deletePartner(id){
  safeWrite(SPONSOR_KEY, getSponsors().filter(x => x.id !== id));
  setMeta({ lastEdited: new Date().toISOString() });
  renderAll();
}

function movePartnerUp(index){
  const partners = getSponsors();
  if(index <= 0) return;
  [partners[index - 1], partners[index]] = [partners[index], partners[index - 1]];
  safeWrite(SPONSOR_KEY, partners);
  renderAll();
}

function movePartnerDown(index){
  const partners = getSponsors();
  if(index >= partners.length - 1) return;
  [partners[index + 1], partners[index]] = [partners[index], partners[index + 1]];
  safeWrite(SPONSOR_KEY, partners);
  renderAll();
}

function saveSettings(){
  const next = {
    title: document.getElementById('setTitle').value.trim() || DEFAULT_SETTINGS.title,
    subtitle: document.getElementById('setSubtitle').value.trim() || DEFAULT_SETTINGS.subtitle,
    explainer: document.getElementById('setExplainer').value.trim() || DEFAULT_SETTINGS.explainer,
    locationName: document.getElementById('setLocationName').value.trim() || DEFAULT_SETTINGS.locationName,
    timezone: document.getElementById('setTimezone').value.trim() || DEFAULT_SETTINGS.timezone,
    latitude: Number(document.getElementById('setLat').value || DEFAULT_SETTINGS.latitude),
    longitude: Number(document.getElementById('setLon').value || DEFAULT_SETTINGS.longitude),
    windyZoom: Number(document.getElementById('setZoom').value || DEFAULT_SETTINGS.windyZoom),
    refreshMinutes: Number(document.getElementById('setRefresh').value || DEFAULT_SETTINGS.refreshMinutes),
    forecastUrl: document.getElementById('setForecastUrl').value.trim() || DEFAULT_SETTINGS.forecastUrl,
    alertsUrl: document.getElementById('setAlertsUrl').value.trim() || DEFAULT_SETTINGS.alertsUrl,
    adminPassword: document.getElementById('setAdminPassword').value.trim() || DEFAULT_SETTINGS.adminPassword
  };

  safeWrite(SETTINGS_KEY, next);
  setMeta({ lastEdited: new Date().toISOString() });
  renderAll();
  loadWeatherData(true);
}

function openAdminShell(){ safeWrite(ADMIN_OPEN_KEY, true); renderAll(); }
function closeAdminShell(){ safeWrite(ADMIN_OPEN_KEY, false); renderAll(); }

function unlockAdmin(){
  const settings = getSettings();
  const entered = document.getElementById('adminPasswordInput').value;
  if(entered === settings.adminPassword){
    openAdminShell();
    document.getElementById('adminShell').scrollIntoView({ behavior:'smooth', block:'start' });
    alert('Admin unlocked.');
  }else{
    alert('Incorrect password.');
  }
}
function lockAdmin(){
  closeAdminShell();
  document.getElementById('adminPasswordInput').value = '';
}

function exportBackup(){
  const data = {
    items: getItems(),
    sponsors: getSponsors(),
    archive: getArchive(),
    settings: getSettings(),
    meta: getMeta(),
    exportedAt: new Date().toISOString(),
    version: getMeta().version
  };

  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'wbn-weathercast-delta-backup.json';
  a.click();
}

function importBackup(json){
  try{
    const data = JSON.parse(json);
    if(data.items) safeWrite(ITEMS_KEY, data.items);
    if(data.sponsors) safeWrite(SPONSOR_KEY, data.sponsors);
    if(data.archive) safeWrite(ARCHIVE_KEY, data.archive);
    if(data.settings) safeWrite(SETTINGS_KEY, { ...DEFAULT_SETTINGS, ...data.settings });
    if(data.meta) safeWrite(META_KEY, { ...DEFAULT_META, ...data.meta });
    renderAll();
    loadWeatherData(true);
    alert('Backup imported.');
  }catch{
    alert('Invalid backup file.');
  }
}

function scheduleRefresh(){
  const settings = getSettings();
  const mins = Math.max(1, Number(settings.refreshMinutes || 15));
  const nextMs = mins * 60 * 1000;

  if(refreshTimerId) clearTimeout(refreshTimerId);
  if(countdownIntervalId) clearInterval(countdownIntervalId);

  const nextAt = Date.now() + nextMs;
  refreshTimerId = setTimeout(() => { loadWeatherData(false); }, nextMs);

  countdownIntervalId = setInterval(() => {
    const diff = nextAt - Date.now();
    if(diff <= 0){
      setText('refreshStatus', 'Refreshing now…');
      clearInterval(countdownIntervalId);
      return;
    }
    const totalSeconds = Math.floor(diff / 1000);
    const mm = String(Math.floor(totalSeconds / 60)).padStart(2,'0');
    const ss = String(totalSeconds % 60).padStart(2,'0');
    setText('refreshStatus', `Refreshing in ${mm}:${ss}`);
  }, 1000);
}

document.getElementById('unlockAdminBtn').addEventListener('click', unlockAdmin);
document.getElementById('lockAdminBtn').addEventListener('click', lockAdmin);
document.getElementById('saveSettingsBtn').addEventListener('click', saveSettings);
document.getElementById('addBulletinBtn').addEventListener('click', addBulletin);
document.getElementById('addPartnerBtn').addEventListener('click', addPartner);
document.getElementById('exportBackupBtn').addEventListener('click', exportBackup);

document.getElementById('importBackupInput').addEventListener('change', (e) => {
  const file = e.target.files?.[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = () => importBackup(reader.result);
  reader.readAsText(file);
});

document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => updateWindyMap(btn.dataset.overlay));
});

(function init(){
  getItems();
  getSponsors();
  getArchive();
  getSettings();
  getMeta();
  renderAll();
  loadWeatherData(true);
})();
</script>
</body>
</html>
